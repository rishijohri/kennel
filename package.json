{
  "name": "kennel",
  "version": "0.1.1",
  "description": "Kennel — a node-based IDE for agentic development. Each canvas node is a real, git-versioned state of your codebase.",
  "author": "Kennel",
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "dist:mac": "npm run dist && bash build/sign-dmg.sh",
    "release": "bash build/release.sh",
    "release:dist": "electron-vite build && electron-builder --publish always && bash build/sign-dmg.sh && gh release upload \"v$npm_package_version\" \"release/Kennel-$npm_package_version-universal.dmg\" --clobber"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@github/copilot-sdk": "^1.0.4",
    "@google/genai": "^2.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@xyflow/react": "^12.3.5",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.460.0",
    "monaco-editor": "^0.55.1",
    "openai": "^6.44.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
